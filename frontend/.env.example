# Vite exposes variables that start with VITE_ (preferred).
# With envPrefix in vite.config.js, NEXT_PUBLIC_* also works if you already use that naming.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional (same values — use one pair only):
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Security:
# - Never commit the service_role key or put it in the frontend — it bypasses RLS.
# - The anon key is bundled into client JS; protect data with RLS (see your SQL policies).
# - Keep .env out of git (see frontend/.gitignore).

# Optional: set the same URL under Supabase Auth → URL configuration for email links.
# VITE_SITE_URL=http://localhost:5173
