NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Supabase (NEW project — same keys as apps/api)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Twilio (wire in M5)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_VALIDATE_SIGNATURE=true

# Deepgram (wire in M5)
DEEPGRAM_API_KEY=

# Google TTS (wire in M5)
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Gemini realtime (wire in M5)
GOOGLE_GENAI_API_KEY=
GEMINI_REALTIME_MODEL=gemini-2.0-flash-exp

# Observability
SENTRY_DSN=

# Cross-service
VETRAPPLY_API_BASE=http://localhost:8080

# Public base URL for Twilio webhooks (ngrok / Railway domain)
BASE_URL=
