NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Supabase (NEW project — wire in M2)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=cvs

# Gemini (wire in M3-M4)
GOOGLE_GENAI_API_KEY=
GEMINI_PACK_MODEL=gemini-2.5-pro
GEMINI_PARSER_MODEL=gemini-2.5-pro

# Observability
SENTRY_DSN=

# CORS
CORS_ORIGINS=http://localhost:5173

# Rate limits
RATE_LIMIT_GLOBAL_PER_MIN=120
RATE_LIMIT_PACKS_PER_HOUR=20

# Feature flags
RUN_LLM_TESTS=0

# Hotline (M5)
HOTLINE_DIAL_NUMBER=

# Stripe (placeholder)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
